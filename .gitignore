# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
backend/node_modules/
packages/*/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# SQLite database files
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# tool output
graphify-out/

# claude-specific (not project code)
CLAUDE.md
.claude/

# private business docs
INVESTOR_PITCH.md
Makefile.intel

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
