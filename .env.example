# Copy to backend/.env and fill in values

JWT_SECRET=change_this_to_a_random_64_char_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:4000
PORT=4000
NODE_ENV=development

ANTHROPIC_API_KEY=sk-ant-...

# Email SMTP — leave blank to log tokens to console instead of sending email
# Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
# Resend:   SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USER=resend  SMTP_PASS=re_xxxx
# Postmark: SMTP_HOST=smtp.postmarkapp.com  SMTP_PORT=587  SMTP_USER=<api-token>  SMTP_PASS=<api-token>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SystemFlow <noreply@systemflow.dev>
